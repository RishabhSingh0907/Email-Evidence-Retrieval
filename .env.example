# Environment Variables for Agentic RAG
# Copy this file to .env and fill in your actual credentials

# OpenAI API Configuration
OPENAI_API_KEY=<your_openai_api_key>      # e.g., sk-xxxx
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.7
OPENAI_EMBED_MODEL=text-embedding-3-small

#GEMINI API Configuration
GEMINI_API_KEY=<your_gemini_api_key>

NEO4J_URI = neo4j<url> #AURA or local Neo4j instance URI
NEO4J_USER = <neo4j_username>
NEO4J_PASS = <neo4j_password>
NEO4J_DATABASE=<database_id>
AURA_INSTANCEID=<instance_id>
AURA_INSTANCENAME=<instance_name>

# File Paths
PDF_FOLDER=path/to/documents
PARSED_OUTPUT_DIR=data/processed/parsed_emails
VECTOR_INDEX_DIR=data/vectors

# Logging Configuration
LOG_LEVEL=INFO
LOG_DIR=logs

# Application Configuration
DEBUG=False
MAX_MESSAGES_IN_CONTEXT=10
